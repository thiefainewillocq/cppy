/*
    IsEven and IsOdd call each other. In C++ one of them needs a forward
    declaration to satisfy the parser. Here neither does.
*/

BOOL IsEven(UW n)
        if (n == 0)
                return TRUE
        return IsOdd(n - 1)

BOOL IsOdd(UW n)
        if (n == 0)
                return FALSE
        return IsEven(n - 1)

int main()
        for (UW i = 0; i < 6; i += 1)
                printf("%zu is %s\n", (size_t)i, IsEven(i) ? "even" : "odd")
        return 0
