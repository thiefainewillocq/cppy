{
        "scopeName": "source.cppy",
        "name": "cppy",
        "patterns": [
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#preprocessor" },
                { "include": "#declarations" },
                { "include": "#control" },
                { "include": "#types" },
                { "include": "#constants" },
                { "include": "#functions" },
                { "include": "#operators" },
                { "include": "#variables" }
        ],
        "repository": {
                "comments": {
                        "patterns": [
                                {
                                        "name": "comment.line.double-slash.cppy",
                                        "match": "//.*$"
                                },
                                {
                                        "name": "comment.block.cppy",
                                        "begin": "/\\*",
                                        "end": "\\*/"
                                }
                        ]
                },
                "strings": {
                        "patterns": [
                                {
                                        "name": "string.quoted.double.cppy",
                                        "begin": "\"",
                                        "end": "\"",
                                        "patterns": [
                                                {
                                                        "name": "constant.character.escape.cppy",
                                                        "match": "\\\\."
                                                }
                                        ]
                                },
                                {
                                        "name": "string.quoted.single.cppy",
                                        "begin": "'",
                                        "end": "'",
                                        "patterns": [
                                                {
                                                        "name": "constant.character.escape.cppy",
                                                        "match": "\\\\."
                                                }
                                        ]
                                }
                        ]
                },
                "preprocessor": {
                        "patterns": [
                                {
                                        "name": "meta.preprocessor.cppy",
                                        "begin": "^(\\s*)(#)\\s*([A-Za-z_][A-Za-z0-9_]*)",
                                        "beginCaptures": {
                                                "2": { "name": "punctuation.definition.directive.cppy" },
                                                "3": { "name": "keyword.control.directive.cppy" }
                                        },
                                        "end": "$",
                                        "patterns": [
                                                { "include": "#strings" },
                                                {
                                                        "name": "entity.name.header.cppy",
                                                        "match": "<[^>]+>|\"[^\"]+\""
                                                }
                                        ]
                                }
                        ]
                },
                "declarations": {
                        "patterns": [
                                {
                                        "name": "meta.namespace.cppy",
                                        "match": "\\b(namespace)\\s+([A-Za-z_][A-Za-z0-9_]*)",
                                        "captures": {
                                                "1": { "name": "keyword.declaration.namespace.cppy" },
                                                "2": { "name": "entity.name.namespace.cppy" }
                                        }
                                },
                                {
                                        "name": "meta.template.cppy",
                                        "begin": "\\b(template)\\s*(<)",
                                        "beginCaptures": {
                                                "1": { "name": "keyword.declaration.template.cppy" },
                                                "2": { "name": "punctuation.definition.template.begin.cppy" }
                                        },
                                        "end": "(>)",
                                        "endCaptures": {
                                                "1": { "name": "punctuation.definition.template.end.cppy" }
                                        },
                                        "patterns": [
                                                {
                                                        "name": "keyword.declaration.type-parameter.cppy",
                                                        "match": "\\b(typename|class)\\b"
                                                },
                                                {
                                                        "name": "entity.name.type.parameter.cppy",
                                                        "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
                                                },
                                                {
                                                        "name": "keyword.operator.ellipsis.cppy",
                                                        "match": "\\.\\.\\."
                                                }
                                        ]
                                },
                                {
                                        "name": "meta.type.declaration.cppy",
                                        "match": "\\b(struct|class|union|enum)\\b(?:\\s+\\b(class)\\b)?(?:\\s+([A-Za-z_][A-Za-z0-9_]*))?",
                                        "captures": {
                                                "1": { "name": "keyword.declaration.type.cppy" },
                                                "2": { "name": "storage.modifier.cppy" },
                                                "3": { "name": "entity.name.type.cppy" }
                                        }
                                }
                        ]
                },
                "control": {
                        "patterns": [
                                {
                                        "name": "keyword.control.conditional.cppy",
                                        "match": "\\b(if|else|switch|case|default)\\b"
                                },
                                {
                                        "name": "keyword.control.loop.cppy",
                                        "match": "\\b(for|while)\\b"
                                },
                                {
                                        "name": "keyword.control.exception.cppy",
                                        "match": "\\b(try|catch|throw)\\b"
                                },
                                {
                                        "name": "keyword.control.flow.cppy",
                                        "match": "\\b(return|break|continue)\\b"
                                }
                        ]
                },
                "constants": {
                        "patterns": [
                                {
                                        "name": "constant.language.cppy",
                                        "match": "\\b(TRUE|FALSE|NULL)\\b"
                                },
                                {
                                        "name": "constant.numeric.cppy",
                                        "match": "\\b(?:0x[0-9A-Fa-f]+|\\d+(?:\\.\\d+)?)(?:[uUlLfF]+)?\\b"
                                }
                        ]
                },
                "functions": {
                        "patterns": [
                                {
                                        "name": "meta.function.cppy",
                                        "match": "\\b([A-Za-z_][A-Za-z0-9_:<>]*)\\s*(?=\\()",
                                        "captures": {
                                                "1": { "name": "entity.name.function.cppy" }
                                        }
                                }
                        ]
                },
                "types": {
                        "patterns": [
                                {
                                        "name": "storage.type.builtin.cppy",
                                        "match": "\\b(?:VOID|BOOL|C8|I8|I16|I32|I64|U8|U16|U32|U64|F32|F64|UW|IW)\\b"
                                },
                                {
                                        "name": "support.type.cppy",
                                        "match": "\\b[A-Z][A-Z0-9_]*\\b(?:\\s*<\\s*[A-Za-z_][A-Za-z0-9_:<>,\\s*&]*\\s*>)?"
                                },
                                {
                                        "name": "storage.modifier.cppy",
                                        "match": "\\b(const|volatile|static|mutable|extern)\\b"
                                }
                        ]
                },
                "operators": {
                        "patterns": [
                                {
                                        "name": "keyword.operator.cppy",
                                        "match": "==|!=|<=|>=|&&|\\|\\||::|->|\\+\\+|--|[+\\-*/%&|^~!=<>]"
                                },
                                {
                                        "name": "punctuation.separator.cppy",
                                        "match": "[,;:]"
                                },
                                {
                                        "name": "punctuation.section.brackets.begin.cppy",
                                        "match": "[\\[{(]"
                                },
                                {
                                        "name": "punctuation.section.brackets.end.cppy",
                                        "match": "[\\]})]"
                                }
                        ]
                },
                "variables": {
                        "patterns": [
                                {
                                        "name": "variable.other.cppy",
                                        "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                                }
                        ]
                }
        }
}
